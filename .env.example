API_BASE_URL=https://cherry-backend-401854471349.europe-west2.run.app
USE_MOCK_DATA=false

# Google Maps API key
# Required for shipping address autocomplete functionality
# Get your API key from: https://console.cloud.google.com/google/maps-apis/
# Make sure to enable "Places API" and "Maps JavaScript API"
GOOGLE_API_KEY=YOUR_API_KEY

# Optional local Firebase emulator setup for debug builds
USE_FIREBASE_EMULATORS=false
FIREBASE_EMULATOR_HOST=localhost
FIREBASE_AUTH_EMULATOR_PORT=9099
FIRESTORE_EMULATOR_PORT=8080
